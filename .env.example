# ============================================
# ArwaPark SaaS — Root Environment Variables
# Copy this to .env and fill in your values
# ============================================

# --- Backend ---
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/arwapark?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_very_long_random_secure_string_minimum_32_chars
JWT_EXPIRE=7d
BACKEND_PORT=5000
CLIENT_URL=https://app.yourdomain.com

# --- Frontend ---
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_DOMAIN=app.yourdomain.com
FRONTEND_PORT=3000
